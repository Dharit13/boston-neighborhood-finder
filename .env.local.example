# Anthropic API key for /api/ai-summary, /api/ai-overview, /api/chat
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Upstash Redis credentials for /lib/rateLimit.ts
# Free tier: https://console.upstash.com/redis
# If both are unset, the rate limiter is disabled (dev-friendly).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google Maps JavaScript API key (client-side map rendering in
# components/results/NeighborhoodMap.tsx). Restrict by HTTP referrer.
# https://console.cloud.google.com/google/maps-apis/credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Maps server-side key for /api/commute (Directions API). Keep secret.
# Can reuse the same project; create a separate key restricted to server IPs.
GOOGLE_MAPS_API_KEY=
